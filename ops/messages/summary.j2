<!DOCTYPE html>
<html>
<head>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
  table { border-collapse: collapse; margin: 16px 0; }
  th, td { border: 1px solid #ccc; padding: 6px 10px; text-align: left; }
  th { background: #f4f4f4; }
  td.pick { color: #888; font-weight: bold; }
</style>
</head>
<body>
<h2>{{ nickname }} draft results</h2>

<h3>Rosters</h3>
<table>
  <thead>
    <tr>
      <th>Pick</th>
      {% for kook in kooks %}<th>{{ kook }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
    {% for row in roster_rows %}
    <tr>
      <td class="pick">{{ loop.index }}</td>
      {% for cell in row %}<td>{{ cell }}</td>{% endfor %}
    </tr>
    {% endfor %}
  </tbody>
</table>

<h3>Year-long picks</h3>
<table>
  <thead>
    <tr>
      {% for kook in kooks %}<th>{{ kook }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
    <tr>
      {% for kook in kooks %}<td>{{ year_long_picks.get(kook, "—") }}</td>{% endfor %}
    </tr>
  </tbody>
</table>
</body>
</html>
